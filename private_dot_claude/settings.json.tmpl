{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/eddiehuang/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "assistant@local-agents": false,
    "coding@local-agents": true,
    "devops@local-agents": false,
    "skill-creator@claude-plugins-official": true,
    "superpowers@local-agents": true
  },
  "extraKnownMarketplaces": {
    "local-agents": {
      "source": {
        "source": "directory",
        "path": "{{ .chezmoi.homeDir }}/.agents"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "editorMode": "vim",
  "verbose": false,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}
