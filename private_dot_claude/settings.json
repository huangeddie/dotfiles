{
  "agentPushNotifEnabled": true,
  "editorMode": "vim",
  "effortLevel": "high",
  "enabledPlugins": {
    "assistant@local-agents": false,
    "coding@local-agents": true,
    "devops@local-agents": false,
    "skill-creator@claude-plugins-official": true,
    "superpowers@local-agents": true
  },
  "extraKnownMarketplaces": {
    "local-agents": {
      "source": {
        "path": "/Users/eddiehuang/.agents",
        "source": "directory"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/eddiehuang/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "model": "opus",
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "remoteControlAtStartup": true,
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "enabled": true
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "tui": "fullscreen",
  "verbose": false
}