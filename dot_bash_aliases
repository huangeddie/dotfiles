# NVIM
alias n='nvim'

# Version control
alias g='git'
alias lg='lazygit'
alias j='jj'
alias ji='jjui'
alias jd='jj diff'

# Diff
alias h='hunk'

# Claude Code
alias cl='claude'

# OpenAI Codex
alias co='codex'

# Obsidian / Second Brain
alias vault='cd ~/Documents/Obsidian/main/ && nvim'

# Navigation
alias la='ls -a'
[[ -d ~/Documents/GitHub/LearnLingo/ ]] && alias lingo='cd ~/Documents/GitHub/LearnLingo/'

# Chezmoi
alias cz='chezmoi'
alias czd='cd $(chezmoi source-path)'

# bun completions
[ -s "~/.bun/_bun" ] && source "~/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
