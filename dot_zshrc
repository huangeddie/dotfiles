eval "$(~/.local/bin/mise activate)"

export EDITOR=nvim
export VISUAL=nvim

alias lg='lazygit'
alias la='ls -a'
[[ -d ~/Documents/GitHub/LearnLingo/ ]] && alias lingo='cd ~/Documents/GitHub/LearnLingo/'
alias c='claude --dangerously-skip-permissions'
[[ -d ~/Documents/Second\ Brain/ ]] && alias vault='cd ~/Documents/Second\ Brain/'

chezmoi-clean() {
  chezmoi managed | while read -r f; do
    [[ ! -e "$HOME/$f" ]] && chezmoi forget "$HOME/$f"
  done
}


# opencode
export PATH="$HOME/.opencode/bin:$PATH"
