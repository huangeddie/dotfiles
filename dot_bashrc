# If not running interactively, don't do anything (leave this at the top of this file)
[[ $- != *i* ]] && return

if [ -n "$BASH_VERSION" ]; then
  if [ -f ~/.local/share/omarchy/default/bash/rc ]; then
    source ~/.local/share/omarchy/default/bash/rc
  elif [ -f /etc/skel/.bashrc ]; then
    source /etc/skel/.bashrc
  fi
fi

export EDITOR=nvim
export VISUAL=nvim
export PAGER=bat

# Point XDG-aware tools (e.g. lazygit) at ~/.config, where chezmoi deploys.
# Without this, macOS lazygit reads ~/Library/Application Support/lazygit instead.
export XDG_CONFIG_HOME="$HOME/.config"

export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.cargo/bin:$PATH"
export PATH="$HOME/.opencode/bin:$PATH"
export PATH="$HOME/.npm-global/bin:$PATH"

if command -v mise >/dev/null 2>&1; then
  if [ -n "$BASH_VERSION" ]; then
    eval "$(mise activate bash)"
  elif [ -n "$ZSH_VERSION" ]; then
    eval "$(mise activate zsh)"
  fi
fi

if [ -n "$BASH_VERSION" ] && [ -f ~/.bash_aliases ]; then
  . ~/.bash_aliases
elif [ -n "$ZSH_VERSION" ] && [ -f ~/.zsh_aliases ]; then
  . ~/.zsh_aliases
fi

eval "$(zoxide init bash)"
