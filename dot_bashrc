# If not running interactively, don't do anything (leave this at the top of this file)
[[ $- != *i* ]] && return

# All the default Omarchy aliases and functions
if [ -f ~/.local/share/omarchy/default/bash/rc ]; then
  source ~/.local/share/omarchy/default/bash/rc
elif [ -f /etc/skel/.bashrc ]; then
  source /etc/skel/.bashrc
fi
# Add your own exports, aliases, and functions here.
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.cargo/bin:$PATH"
#
# Make an alias for invoking commands you use constantly
# alias p='python'
alias lg='lazygit'
[[ -d ~/Documents/Second\ Brain/ ]] && alias vault='cd ~/Documents/Second\ Brain/'
alias la='ls -a'

[[ -d ~/Documents/GitHub/LearnLingo/ ]] && alias lingo='cd ~/Documents/GitHub/LearnLingo/'
alias c='claude --dangerously-skip-permissions'

# Auto-attach to tmux session
alias ta='tmux new -A'

# Source aliases
if [ -f ~/.bash_aliases ]; then
  . ~/.bash_aliases
fi

