{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -eu

if ! command -v brew >/dev/null 2>&1; then
  echo "==> Installing Homebrew"
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Homebrew reads its tap-trust allowlist from $XDG_CONFIG_HOME/homebrew/
# when XDG_CONFIG_HOME is set and ~/.homebrew/ otherwise. This script runs
# under non-login bash, which never sources .bashrc, so set it explicitly to
# match interactive shells -- otherwise the two read different files.
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

# packages.yaml is authoritative: --cleanup --force uninstalls anything
# installed that is not declared there.
echo "==> Syncing Homebrew packages via brew bundle (strict)"
brew bundle --file=/dev/stdin --cleanup --force <<EOF
{{ range .packages.darwin.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF

{{- end }}
